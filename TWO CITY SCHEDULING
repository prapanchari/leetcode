#include <stdio.h>
#include <stdlib.h>


int compare(const void* a, const void* b) {
    int* person1 = *(int**)a;
    int* person2 = *(int**)b;
    
    int diff1 = person1[0] - person1[1]; 
    int diff2 = person2[0] - person2[1]; 
    
    return diff1 - diff2; 
}

int twoCitySchedCost(int** costs, int costsSize, int* costsColSize) {

    qsort(costs, costsSize, sizeof(int*), compare);
    
    int totalCost = 0;
    int n = costsSize / 2; 
    
    
    for (int i = 0; i < n; i++) {
        totalCost += costs[i][0]; 
    }
    
    for (int i = n; i < costsSize; i++) {
        totalCost += costs[i][1]; 
    }
    
    return totalCost;
}
