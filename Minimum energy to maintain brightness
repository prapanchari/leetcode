#include <stdio.h>
#include <stdlib.h>

typedef struct {
    int start;
    int end;
} Interval;

int compareIntervals(const void* a, const void* b) {
    Interval* int1 = (Interval*)a;
    Interval* int2 = (Interval*)b;
    if (int1->start != int2->start) {
        return (int1->start < int2->start) ? -1 : 1;
    }
    return (int1->end < int2->end) ? -1 : 1;
}

long long minEnergy(int n, int brightness, int** intervals, int intervalsSize, int* intervalsColSize) {
    if (intervalsSize == 0) return 0;

    Interval* arr = (Interval*)malloc(intervalsSize * sizeof(Interval));
    for (int i = 0; i < intervalsSize; i++) {
        arr[i].start = intervals[i][0];
        arr[i].end = intervals[i][1];
    }

    qsort(arr, intervalsSize, sizeof(Interval), compareIntervals);

    long long total_active_time = 0;
    int current_start = arr[0].start;
    int current_end = arr[0].end;

    for (int i = 1; i < intervalsSize; i++) {
        if (arr[i].start <= current_end) {
            if (arr[i].end > current_end) {
                current_end = arr[i].end;
            }
        } else {
            total_active_time += (long long)(current_end - current_start + 1);
            current_start = arr[i].start;
            current_end = arr[i].end;
        }
    }
    total_active_time += (long long)(current_end - current_start + 1);

    long long bulbs_needed = (brightness + 2) / 3;

    free(arr);

    return bulbs_needed * total_active_time;
}
