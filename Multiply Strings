#include <string.h>
#include <stdlib.h>

char* multiply(char* num1, char* num2) {
 
    if (strcmp(num1, "0") == 0 || strcmp(num2, "0") == 0) {
        char* zero = (char*)malloc(2 * sizeof(char));
        zero[0] = '0';
        zero[1] = '\0';
        return zero;
    }
    
    int m = strlen(num1);
    int n = strlen(num2);
    int max_len = m + n;
    
    
    int* result = (int*)calloc(max_len, sizeof(int));
    
    
    for (int i = m - 1; i >= 0; i--) {
        for (int j = n - 1; j >= 0; j--) {
            int mul = (num1[i] - '0') * (num2[j] - '0');
            int p1 = i + j;
            int p2 = i + j + 1;
            
            int sum = mul + result[p2];
            result[p2] = sum % 10;
            result[p1] += sum / 10;
        }
    }
    
   
    char* final_str = (char*)malloc((max_len + 1) * sizeof(char));
    int res_idx = 0;
    

    int start_pos = (result[0] == 0) ? 1 : 0;
    
   
    for (int i = start_pos; i < max_len; i++) {
        final_str[res_idx++] = result[i] + '0';
    }
    final_str[res_idx] = '\0'; // Append null terminator
    
   
    free(result);
    
    return final_str;
}
